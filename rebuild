#!/usr/bin/env fish

# Temporarily stage the secrets file so Nix can access it during the build
git -C ~/nixos add -f ~/nixos/secrets.json

# Output the exact derivation path of the upstream Chromium-MV2 package before rebuilding
echo "🔍 Target Chromium-MV2 drvPath (from GitHub):"
nix eval github:naminx/chromium-mv2#default.drvPath
echo "🔍 Resolved Chromium-MV2 drvPath (from Local NixOS Flake):"
nix eval ~/nixos#nixosConfigurations.nixos.pkgs.chromium-mv2.drvPath


# The 'if' statement directly checks the exit code of the nixos-rebuild command.
# The code inside this block will only run if the command succeeds (returns exit code 0).
if sudo nice -n 19 nixos-rebuild switch --flake ~/nixos\#nixos --option log-lines 1000
    echo "✅ NixOS rebuild successful."

    # Check for the '-r' flag to relink services
    if test "$argv[1]" = "-r"
        echo "🔗 Relinking services..."

        # Relink user services
        for service in gnome-remote-desktop onedrive@onedrive
            # Cycle through actions to ensure service is reloaded and running
            for action in stop disable enable start
                systemctl --user $action $service
            end
        end

        # Relink system services
        sudo systemctl restart guacamole-server.service
        sudo systemctl restart tomcat.service
        echo "✅ Services relinked."
    end
else
    # This 'else' block runs if the nixos-rebuild command fails
    echo "❌ NixOS rebuild failed. No services were relinked."
end

# This command now runs regardless of whether the build succeeded or failed,
# ensuring the secret is always removed from the git staging area.
echo "🧹 Cleaning up staged secrets..."
git -C ~/nixos rm --cached ~/nixos/secrets.json
